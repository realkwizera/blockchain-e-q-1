FROM node:18-alpine

WORKDIR /app

# Install curl for health checks
RUN apk add --no-cache curl

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Expose Hardhat node port
EXPOSE 8545

# Default command (can be overridden)
CMD ["npx", "hardhat", "node", "--hostname", "0.0.0.0"]